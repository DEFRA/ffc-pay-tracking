  <changeSet author="Leigh Godson" id="2">
    <sql>
      UPDATE public."reportData"
      SET value = value * -1
      WHERE "sourceSystem" = 'FPTT'
        AND "lastUpdated"::date &lt;= CURRENT_DATE
        AND value &lt; 0;
    </sql>
  </changeSet>
</databaseChangeLog>
